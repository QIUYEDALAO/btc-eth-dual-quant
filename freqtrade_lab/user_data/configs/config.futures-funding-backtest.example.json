    "price_side": "other",
    "use_order_book": false
  },
  "api_server": {
    "enabled": false,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8080,
    "username": "",
    "password": "",
    "jwt_secret_key": "somethingRandomSomethingRandom123",
    "verbosity": "error"
  },
  "telegram": {
    "enabled": false,
    "token": "",
    "chat_id": ""
  },
  "bot_name": "btc-eth-dual-quant-m1b-futures-funding-lab",
