{
  "dry_run": true,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "max_open_trades": 2,
  "stake_currency": "USDT",
  "stake_amount": 100,
  "tradable_balance_ratio": 0.5,
  "fiat_display_currency": "USD",
  "timeframe": "1d",
  "dataformat_ohlcv": "jsongz",
  "cancel_open_orders_on_exit": false,
  "exchange": {
    "name": "binance",
    "ccxt_config": {
      "enableRateLimit": true,
      "options": {
