      }
    },
    "ccxt_async_config": {
      "enableRateLimit": true,
      "options": {
        "defaultType": "future"
      }
    },
    "pair_whitelist": [
      "BTC/USDT:USDT",
      "ETH/USDT:USDT"
    ],
    "pair_blacklist": []
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "entry_pricing": {
    "price_side": "other",
